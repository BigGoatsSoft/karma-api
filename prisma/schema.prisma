generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BotPersonality {
  usual
  business
  bad_guy
}

model User {
  id                     String         @id @default(uuid())
  email                  String         @unique
  name                   String
  hashedSub              String?        @unique
  hashedAppleSub         String?        @unique
  passwordHash           String?
  country                String         @default("")
  botPersonality         BotPersonality @default(usual)
  karmaDailyGoal         Int            @default(0)
  karma                  Int            @default(0)
  isNotificationReminder Boolean        @default(false)
  karmaCoins             Int            @default(200)
  lastCoinReset          DateTime       @default(now())
  subscriptionType       String         @default("free")
  subscriptionExpiry     DateTime?
  karmaEntries           KarmaEntry[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
}

model KarmaEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  karma     Int
  text      String
  createdAt DateTime @default(now())

  @@index([userId])
}
