DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/karma?schema=public"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# HMAC key for storing Google account subject (`sub`) as hashedSub (use a long random string)
GOOGLE_SUB_SECRET=

# Prisma CLI loads env via prisma.config.ts (dotenv). After pulling: npm install && npm run prisma:generate
